<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- CONSOLE Appender: Prints logs to the terminal -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %highlight(%-5level) %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- LOGGER: Set specific log levels for your packages -->
    <logger name="com.qsl.parser" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE" />
    </logger>

    <!-- ROOT Logger: Fallback for all other logs -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>
</configuration>
